NODE_ENV=development

# Web
VITE_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_editor
REDIS_URL=redis://localhost:6379

# Object storage compatible with S3 APIs, such as Cloudflare R2.
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Video analysis CLI tools
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
SCENEDETECT_BIN=scenedetect
WHISPER_BIN=whisper
WHISPER_MODEL=base
VIDEO_ANALYSIS_WORK_DIR=
VIDEO_ANALYSIS_COMMAND_TIMEOUT_MS=600000
VIDEO_ANALYSIS_MAX_KEYFRAMES=120
ALLOW_LOCAL_VIDEO_INPUT=false
VIDEO_INPUT_ROOT=
KEEP_ANALYSIS_WORKDIR=false
