{
  "name": "ai-editor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @ai-editor/web dev",
    "dev:api": "pnpm --filter @ai-editor/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @ai-editor/api prisma:generate",
    "db:migrate": "pnpm --filter @ai-editor/api prisma:migrate"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
